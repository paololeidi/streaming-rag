# Copy this file to .env and fill in your values.

# LangSmith — obtain from https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ai-project

# Ollama model to use for the agent (must support tool/function calling)
# Recommended: llama3.2:3b (~2GB RAM), qwen2.5:3b (~2GB RAM), llama3.1 (4.7GB RAM)
OLLAMA_MODEL=llama3.2:3b

# Keep the model loaded in RAM between requests (prevents cold-start reload penalty)
# Use "0" to unload immediately after each request (saves RAM at cost of reload time)
OLLAMA_KEEP_ALIVE=30m

# Ollama base URL (change if Ollama runs on a non-default host/port)
OLLAMA_BASE_URL=http://localhost:11434
