# Copy this file to .env and fill in your values.

# LangSmith — obtain from https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ai-project

# Ollama model to use for the agent (must support tool/function calling)
# Recommended: llama3.2:3b (~2GB RAM), qwen2.5:3b (~2GB RAM), llama3.1 (4.7GB RAM)
OLLAMA_MODEL=llama3.2:3b

# Keep the model loaded in RAM between requests (prevents cold-start reload penalty)
# Use "0" to unload immediately after each request (saves RAM at cost of reload time)
OLLAMA_KEEP_ALIVE=30m

# Ollama base URL
# Host / non-Docker: http://localhost:11434
# Compose sets http://ollama:11434 on the api service — leave this for local runs
OLLAMA_BASE_URL=http://localhost:11434

# Kafka bootstrap servers
# Host / non-Docker: localhost:9092
# Compose sets kafka:29092 on app services
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ChromaDB
# Host / non-Docker: leave CHROMA_HOST empty to use embedded PersistentClient
# Compose sets CHROMA_HOST=chroma on consumer, api, and mcp
# CHROMA_HOST=
# CHROMA_PORT=8000
# CHROMA_PERSIST_DIR=  # only used when CHROMA_HOST is empty

# MCP server port — used when running the MCP server in SSE mode (--sse flag)
MCP_SERVER_PORT=8001

# MCP server URL — set this to let the LangGraph agent load tools from an MCP
# server at startup (SSE transport). Leave empty to use native tools only.
# Compose MCP SSE: http://localhost:8001/sse (from host) or http://mcp:8001/sse (in-network)
# Start the MCP server first: python src/mcp_server/server.py --sse
MCP_SERVER_URL=
